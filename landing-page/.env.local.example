# Sanity — same project ID as client-nexa-academy.
# Create a separate dataset (e.g. "landing") to keep content isolated.
NEXT_PUBLIC_SANITY_PROJECT_ID=qg0o7wrr
NEXT_PUBLIC_SANITY_DATASET=landing

# Server-side read token (needed for draft previews; safe to omit for public read)
SANITY_API_READ_TOKEN=

# Secret that Sanity sends in the X-Sanity-Webhook-Signature header
SANITY_WEBHOOK_SECRET=

# Existing Nexa Academy platform API (programs + intakes are read-only from here)
NEXT_PUBLIC_API_BASE_URL=https://api.nexaacademy.co.ke

# Future admissions platform — application actions point here once migrated
NEXT_PUBLIC_ADMISSIONS_URL=https://admissions.nexaacademy.co.ke
