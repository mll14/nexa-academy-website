# Admissions Portal — environment variables
# Copy to .env.local and fill in values

# API base URL — Vite bakes this into the build at compile time.
# For local dev, point at the Django dev server:
# VITE_API_URL=http://127.0.0.1:8000/api
# For production (set this in Coolify env vars, not here):
# VITE_API_URL=https://api.nexaacademy.co.ke/api

# Google OAuth (for student login with Google)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Paystack public key (for payment initialization)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Keycloak SSO (Phase 4). Leave VITE_AUTH_PROVIDER unset (or =django) to keep the
# existing Django login. Set =keycloak only once the realm is live and tested.
# VITE_AUTH_PROVIDER=keycloak
# VITE_KEYCLOAK_URL=https://auth.nexaacademy.co.ke
# VITE_KEYCLOAK_REALM=Nexa Academy Auth
# VITE_KEYCLOAK_CLIENT_ID=nexa-admissions-app
